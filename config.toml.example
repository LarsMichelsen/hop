# Example configuration file for hop
# Place this file at: ~/.config/hop/config.toml

# UI options
[ui]
# Theme: "auto" (default — honours $HOP_THEME, otherwise adapts to the
# terminal's ANSI color palette), "light", "dark", or any built-in Textual
# theme name such as "nord", "gruvbox", "dracula", "monokai", "tokyo-night",
# "catppuccin-mocha", "catppuccin-latte", "solarized-light", "flexoki",
# "textual-ansi".
theme = "auto"

# Default prefix for branches not specified in [branch_prefixes]
[defaults]
branch_prefix = ""

# Branch-specific prefixes
# Maps base branch names to prefixes for new branches created from them
[branch_prefixes]
main = "feature/"
master = "feature/"
develop = "feat/"
staging = "hotfix/"
production = "hotfix/"

# Example with branch names containing special characters
# Use quotes for branch names with slashes or other special characters
# "release/v1.0" = "bugfix/"
